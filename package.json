{
  "name": "zen-capsule",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm -w packages/backend run dev",
    "build:backend": "npm -w packages/backend run build",
    "build:shared": "npm -w packages/shared run build",
    "db:migrate": "npm -w packages/backend run db:migrate",
    "db:generate": "npm -w packages/backend run db:generate",
    "db:studio": "npm -w packages/backend run db:studio",
    "build:extension": "npm -w packages/extension run build",
    "dev:extension": "npm -w packages/extension run dev"
  },
  "devDependencies": {
    "@react-native/metro-config": "^0.84.1"
  }
}
