{
  "name": "zen-capsule-desktop",
  "version": "0.1.0",
  "description": "Zen Capsule — Digital Barrier for Mac (Menu Bar App)",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.zencapsule.desktop",
    "productName": "Zen Capsule",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": "dmg",
      "hardenedRuntime": true,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
