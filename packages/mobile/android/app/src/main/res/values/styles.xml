<resources>

    <!-- Base application theme with warm cream splash screen. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <!-- Warm cream splash background while JS bundle loads -->
        <item name="android:windowBackground">@color/zen_splash_bg</item>
        <item name="android:statusBarColor">@color/zen_bg</item>
        <item name="android:navigationBarColor">@color/zen_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

</resources>
