# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zen_capsule

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
PORT=3001
NODE_ENV=development

# Admin export key
EXPORT_KEY=change-me-in-production

# RevenueCat webhook secret — set the SAME value as the Authorization header in
# the RevenueCat dashboard (Project → Webhooks). Required only for real billing.
REVENUECAT_WEBHOOK_SECRET=change-me-in-production
